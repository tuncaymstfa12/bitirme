FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache \
    poppler-utils \
    tesseract-ocr \
    tesseract-ocr-data-eng \
    tesseract-ocr-data-tur

COPY package.json package-lock.json ./
RUN npm install --production

COPY server/ ./server/

ENV AUTH_API_PORT=8000

EXPOSE 8000

CMD ["node", "server/server.js"]
